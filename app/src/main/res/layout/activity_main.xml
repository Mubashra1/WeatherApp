<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/main_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#x1F324;&#xFE0F;"
            android:textSize="52sp"
            android:layout_marginTop="40dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Weather"
            android:textColor="#ffffff"
            android:textSize="42sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:gravity="center"
            android:letterSpacing="0.05"
            android:layout_marginTop="6dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&#x2601;&#xFE0F;  &#x26C5;  &#x1F327;&#xFE0F;  &#x2600;&#xFE0F;  &#x2744;&#xFE0F;"
            android:textSize="22sp"
            android:gravity="center"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live weather updates"
            android:textColor="#7ab8f5"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="36dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:background="@drawable/search_bg">

            <EditText
                android:id="@+id/etCity"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:hint="Enter city name..."
                android:textColor="#ffffff"
                android:textColorHint="#5588aa"
                android:background="@null"
                android:paddingStart="18dp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:singleLine="true"
                android:textSize="15sp"/>

            <Button
                android:id="@+id/btnSearch"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Search"
                android:textColor="#ffffff"
                android:textStyle="bold"
                android:backgroundTint="#1565c0"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"/>

        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="40dp"
            android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/weatherCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_bg"
            android:padding="24dp"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/tvWeatherEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#x1F324;&#xFE0F;"
                android:textSize="80sp"/>

            <TextView
                android:id="@+id/tvCityName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#ffffff"
                android:textSize="24sp"
                android:textStyle="bold"
                android:fontFamily="serif"
                android:gravity="center"
                android:layout_marginTop="6dp"
                android:text="City Name"/>

            <TextView
                android:id="@+id/tvTemperature"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#ffffff"
                android:textSize="80sp"
                android:textStyle="bold"
                android:gravity="center"
                android:text="--"/>

            <TextView
                android:id="@+id/tvDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#7ab8f5"
                android:textSize="16sp"
                android:gravity="center"
                android:layout_marginTop="2dp"
                android:text="Clear Sky"/>

            <TextView
                android:id="@+id/tvWeatherComment"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#aaddff"
                android:textSize="13sp"
                android:fontFamily="serif"
                android:textStyle="italic"
                android:gravity="center"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="16dp"
                android:text="Stay safe out there!"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#22ffffff"
                android:layout_marginBottom="20dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/stat_bg"
                    android:padding="14dp"
                    android:layout_marginEnd="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x1F4A7;"
                        android:textSize="26sp"/>

                    <TextView
                        android:id="@+id/tvHumidity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--%"
                        android:textColor="#ffffff"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Humidity"
                        android:textColor="#7ab8f5"
                        android:textSize="11sp"/>

                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/stat_bg"
                    android:padding="14dp"
                    android:layout_marginStart="6dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x1F4A8;"
                        android:textSize="26sp"/>

                    <TextView
                        android:id="@+id/tvWind"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-- km/h"
                        android:textColor="#ffffff"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:layout_marginTop="4dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Wind Speed"
                        android:textColor="#7ab8f5"
                        android:textSize="11sp"/>

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/tvError"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#ff6b6b"
            android:textSize="15sp"
            android:gravity="center"
            android:layout_marginTop="20dp"
            android:visibility="gone"
            android:text="City not found. Please try again."/>

    </LinearLayout>
</ScrollView>